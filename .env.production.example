# Production Environment Variables Template
# Copy this file to .env.production and update all values
#
# IMPORTANT: Never commit .env.production to version control
# Add .env.production to .gitignore

# ============================================
# APPLICATION SETTINGS
# ============================================

# Application environment (MUST be "production" for beta/production)
APP_ENV=production

# Public teacher registration (MUST be "false" in production)
# Teachers should be created manually or via seed script
ENABLE_PUBLIC_REGISTER=false

# ============================================
# SECURITY - CRITICAL
# ============================================

# Secret key for JWT token signing and session security
# MUST be changed from default. Generate with: openssl rand -hex 32
# WARNING: Application will refuse to start if this is not changed from dev default
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL connection URL
# Format: postgresql://username:password@host:port/database
# For Docker Compose: host is "postgres" (service name)
DATABASE_URL=postgresql://apcs:replace-with-strong-password@postgres:5432/ap_cs_practice

# PostgreSQL credentials (used by docker-compose.prod.yml)
POSTGRES_USER=apcs
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=ap_cs_practice

# ============================================
# CORS CONFIGURATION
# ============================================

# Allowed origins for CORS (comma-separated)
# Set to your deployed frontend domain(s)
# Example: https://app.example.com,https://www.example.com
CORS_ORIGINS=https://your-frontend-domain.com

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Backend API URL (used by Next.js frontend)
# Set to your deployed backend domain
# Example: https://api.example.com
NEXT_PUBLIC_API_URL=https://your-backend-domain.com

# ============================================
# JAVA RUNNER CONFIGURATION
# ============================================

# Docker image name for Java runner
JAVA_RUNNER_IMAGE=ap-cs-java-runner

# Memory limit per Java execution container
JAVA_RUNNER_MEMORY=256m

# CPU limit per Java execution container (0.5 = 50% of one core)
JAVA_RUNNER_CPUS=0.5

# Maximum execution time in seconds
JAVA_RUNNER_TIMEOUT=5

# Maximum number of processes per container
JAVA_RUNNER_PIDS_LIMIT=64

# Temporary directory for Java code execution
# WARNING: This directory must exist on the host and be accessible by Docker
JAVA_RUNNER_TMP_DIR=/tmp/ap-cs-practice-lab-java-runs

# ============================================
# PRODUCTION CHECKLIST
# ============================================
#
# Before starting production deployment, verify:
#
# [ ] Changed SECRET_KEY to a secure random value
# [ ] Changed POSTGRES_PASSWORD to a strong password
# [ ] Set APP_ENV=production
# [ ] Set ENABLE_PUBLIC_REGISTER=false
# [ ] Updated CORS_ORIGINS to actual frontend domain
# [ ] Updated NEXT_PUBLIC_API_URL to actual backend domain
# [ ] Reviewed Java runner security implications
# [ ] Configured firewall (ports 22, 80, 443 only)
# [ ] Set up HTTPS with Caddy or Nginx
# [ ] Planned database backup strategy
# [ ] Reviewed docs/VPS_PRODUCTION_CONFIG.md
# [ ] Reviewed docs/DEPLOYMENT_CHECKLIST.md
#
# ============================================
# DEPLOYMENT COMMANDS
# ============================================
#
# 1. Copy this file:
#    cp .env.production.example .env.production
#
# 2. Edit .env.production with real values:
#    nano .env.production  # or vim, code, etc.
#
# 3. Start services:
#    docker compose -f docker-compose.prod.yml --env-file .env.production up --build -d
#
# 4. Verify health:
#    curl http://localhost:8000/health
#    curl http://localhost:3000
#
# 5. Initialize database (if first deployment):
#    docker compose -f docker-compose.prod.yml --env-file .env.production exec backend python seed.py
#
# 6. Check logs:
#    docker compose -f docker-compose.prod.yml logs -f
#
# ============================================
# BACKUP COMMANDS
# ============================================
#
# Backup database:
#   docker compose -f docker-compose.prod.yml exec postgres pg_dump -U apcs ap_cs_practice > backup.sql
#
# Restore database:
#   cat backup.sql | docker compose -f docker-compose.prod.yml exec -T postgres psql -U apcs ap_cs_practice
#
# See docs/BACKUP_AND_RESTORE.md for detailed instructions
#
# ============================================
# SECURITY REMINDERS
# ============================================
#
# - Never commit .env.production to git
# - Never use dev SECRET_KEY in production
# - Never expose PostgreSQL port 5432 to public internet
# - Never enable ENABLE_PUBLIC_REGISTER in production
# - Never show real student data in screenshots or demos
# - Keep beta trial small (3-5 teachers max)
# - Use anonymized student accounts only
# - Review Docker socket security implications
#
# ============================================
# SUPPORT
# ============================================
#
# For deployment help, see:
# - docs/VPS_BETA_DEPLOYMENT_PLAN.md
# - docs/VPS_PRODUCTION_CONFIG.md
# - docs/DEPLOYMENT_CHECKLIST.md
# - docs/BACKUP_AND_RESTORE.md
# - docs/REVERSE_PROXY_NOTES.md
